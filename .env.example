# Database
# Leave unset to use the local SQLite fallback at ./data/medrota.db
DATABASE_URL=
DATA_DIR=./data
AUTO_SEED_SAMPLE_DATA=true

# API
API_TITLE=Medical Rostering Automation API
API_VERSION=1.0.0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://frontend-cyan-beta-65.vercel.app

# Scheduler
SCHEDULER_TIMEOUT_SECONDS=300
SCHEDULER_MAX_ITERATIONS=1000

# Fairness
FAIRNESS_NIGHT_TOLERANCE=2
FAIRNESS_WEEKEND_TOLERANCE=1
FAIRNESS_ONCALL_TOLERANCE=1
FAIRNESS_SCORE_TARGET=85.0

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI Copilot
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
